[
  // Overleaf と同じ ⌘Enter で再コンパイル（⌘S/C-x C-s の保存時ビルドと併用）
  {
    "key": "cmd+enter",
    "command": "latex-workshop.build",
    "when": "editorLangId == 'latex'"
  },
  // Ctrl+. : 再コンパイル（synctex.afterBuild により完了後 PDF がカーソル行へ自動移動）
  {
    "key": "ctrl+.",
    "command": "latex-workshop.build",
    "when": "editorLangId == 'latex'"
  },
  // Shift+Enter : ターミナルに改行を送る（Claude Code の複数行入力用）
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": {
      "text": "\u001b\r"
    },
    "when": "terminalFocus"
  }
]
