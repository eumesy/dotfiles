# 対話ツール（fzf/zoxide、compinit が呼ぶ mv）は brew の /opt/homebrew/bin と system の /bin を
# 前提にするが、それらを通すのはログイン専用の ~/.zprofile（brew shellenv）と /etc/zprofile
# （path_helper）だけ。自動リロード（下の precmd 再 source）や非ログイン対話シェルはそれらを
# 再実行しないため、欠けているときだけ冪等に補う（通過済みのログインシェルには足さない）。
# system は path_helper（PATH 全体を macOS 標準順に再構成する）ではなく末尾追記で補い、既存の
# .local/bin → brew → system の順序を保つ（brew だけ残り /bin 欠落という稀状態でも降格させない）。
[[ ":$PATH:" == *":/bin:"* ]] || path+=(/usr/bin /bin /usr/sbin /sbin)   # system（mv 等）
[[ -x /opt/homebrew/bin/brew && ":$PATH:" != *":/opt/homebrew/bin:"* ]] && eval "$(/opt/homebrew/bin/brew shellenv)"  # /opt/homebrew/bin（fzf, zoxide）
export PATH="$HOME/.local/bin:$PATH"
typeset -U path PATH  # 重複エントリを自動排除（再 source・上の通し直しでも増えない）

# ここから下は対話 shell 専用。非対話 shell（スクリプト・Claude Code 等のエージェントが
# 打つコマンド）に、対話用エイリアス（ls=eza など）・chpwd 自動 ls・fzf/zoxide・補完を
# 読み込ませない。漏れると ls=eza のソート指定やフラグ差でコマンドが期待どおり動かず
# 手戻りになる（BSD ls とは -t 等の意味が違う）。PATH は上で通済みなのでここで抜ける。
[[ -o interactive ]] || return 0

# fzf のキーバインド・補完 (Ctrl-R 履歴検索など)。未インストール／PATH 欠落時のエラー抑止に command -v でガード
command -v fzf >/dev/null 2>&1 && source <(fzf --zsh)

# Ctrl-] : ghq 管理下のリポジトリを fzf でインクリメンタル検索して cd
# ghq/fzf が無い環境ではキー押下時の command not found を避けるため、両方あるときだけ定義・bind
if command -v ghq >/dev/null 2>&1 && command -v fzf >/dev/null 2>&1; then
  function ghq-fzf() {
    local repo=$(ghq list | fzf --reverse --height 40%)
    [ -n "$repo" ] && cd "$(ghq root)/$repo" && zle reset-prompt
  }
  zle -N ghq-fzf
  bindkey '^]' ghq-fzf
fi

# コマンド履歴をファイルに保存（これが無いと Ctrl-R = fzf 履歴検索がセッションを跨げない）
# macOS デフォルト（/etc/zshrc の SAVEHIST=1000）を引き上げる。ファイルは同じ ~/.zsh_history
HISTFILE=~/.zsh_history
HISTSIZE=100000              # メモリ上に保持する件数
SAVEHIST=100000              # ファイルに保存する件数
setopt hist_ignore_all_dups  # 重複コマンドは最新のみ残す
setopt share_history         # 複数セッション間で履歴を共有
setopt extended_history      # 実行時刻・所要時間も記録

# 入力途中の文字列から始まる履歴を Ctrl-P / Ctrl-N で遡る/進む
autoload -Uz history-search-end
zle -N history-beginning-search-backward-end history-search-end
zle -N history-beginning-search-forward-end history-search-end
bindkey '^P' history-beginning-search-backward-end
bindkey '^N' history-beginning-search-forward-end

# ディレクトリ名だけの単一ワード入力（`../`・`..`・相対/絶対パス。引数を伴わない場合のみ）で cd する
# エイリアス・関数・組み込み・PATH 上のコマンドとして実行できる名前が優先されるため、同名ディレクトリで誤爆はしない
setopt auto_cd

# zoxide: 訪れたディレクトリを frecency（頻度 + 新しさ）で自動記録
# `z <キーワード>` でジャンプ、`zi` で対話選択（fzf 使用）。fzf と同様 command -v でガード
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
  # 記録は chpwd（cd 時）フックのみなので、Finder の「Ghostty で開く」等で最初から
  # 目的ディレクトリで起動した shell は記録されない → 起動時の場所も明示的に記録する。
  # ・$HOME は除外（通常の新規ターミナルは毎回 ~ で始まり、~ のスコアだけ膨らむため）。
  #   :A の実体パス比較で、symlink 経由で home にいる場合も除外する
  # ・自動リロード（precmd での再 source）のたびに加算しないよう、starship と同じ
  #   非 export フラグで「そのシェルで一度だけ」に絞る（exec zsh=reload・新規起動では記録される）
  # ・パスは chpwd フックと同じ __zoxide_pwd で取得（_ZO_RESOLVE_SYMLINKS を使っても DB が割れない）
  if [[ -z ${_ZOXIDE_STARTUP_ADDED:-} && "${PWD:A}" != "${HOME:A}" ]]; then
    command zoxide add -- "$(__zoxide_pwd)"
    _ZOXIDE_STARTUP_ADDED=1
  fi
fi

# Ctrl-L : 過去に訪れたディレクトリを fzf で検索して cd（frecency 順）
# zoxide/fzf が無い環境ではキー押下時の command not found を避けるため、両方あるときだけ定義・bind
if command -v zoxide >/dev/null 2>&1 && command -v fzf >/dev/null 2>&1; then
  function fzf-zoxide() {
    local dir=$(zoxide query --list | fzf --reverse --height 40% --no-sort)
    if [ -n "$dir" ]; then
      BUFFER="cd ${(q)dir}"
      zle accept-line
    fi
  }
  zle -N fzf-zoxide
  bindkey '^l' fzf-zoxide
fi

# 補完を有効化し、候補にファイル種別の色を付ける（LS_COLORS は 2021 年設定を踏襲）
autoload -Uz compinit && compinit
export LS_COLORS='di=01;36:ln=01;35:ex=01;32'
zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}

# ls: eza（exa 後継のモダン ls。色・git 状態・tree 表示・アイコン）。無ければ BSD ls で代替
# --icons=auto: 出力が端末のときだけ Nerd Font グリフのアイコンを付ける（パイプ時は付かない）。
# 表示には Nerd Font が必要（Ghostty は内蔵。VS Code ターミナルは vscode/settings.json の
# terminal.integrated.fontFamily + Brewfile の font-jetbrains-mono-nerd-font で対応）
if command -v eza >/dev/null 2>&1; then
  alias ls='eza -A --icons=auto'                   # 隠しファイル込み（2021 年の ls -A を踏襲）
  alias ll='eza -lhA --git --icons=auto'           # 詳細表示 + git 状態（旧 ll='ls -lhGAF' 相当）
  alias lt='eza -A --tree --level=2 --icons=auto'  # 2 階層のツリー表示
else
  alias ls='ls -AGF'
  alias ll='ls -lhAGF'
fi

# of: カレントディレクトリを macOS の Finder で開く（open + Finder の頭文字）
alias of='open .'

# less: bat（syntax highlight 付き cat/pager）を前処理にして less 内でハイライト表示
# LESSOPEN: less がファイルを開くときに bat で色付けする（`cmd | less` のパイプ入力は対象外）
# LESS=-R: 色の ANSI エスケープをそのまま解釈して表示
# --style=plain: 行番号や枠を付けない（less らしい見た目のまま。コピーも汚れない）
if command -v bat >/dev/null 2>&1; then
  export LESSOPEN='| bat --color=always --style=plain %s'
  export LESS='-R'
fi

# cd 直後に ls を自動実行（2021 年の chpwd() を踏襲。zoxide のフックと共存できる add-zsh-hook 方式）
# ※ 直前で定義した ls エイリアス（= eza）がこの関数の定義時に展開される
# ※ eza は「引数なし + stdin が非端末」だと stdin からパス一覧を読む仕様のため、明示的に . を渡す
autoload -Uz add-zsh-hook
function ls-on-chpwd() {
  ls .
}
add-zsh-hook chpwd ls-on-chpwd

# ~/.zshrc（の実体）が更新されていたら、次のプロンプト表示前に自動で再読み込み
# （dotfiles の編集・pull 後、開いている各ターミナルは Enter を打つだけで反映される）
# ※ source の重ね掛けのため設定の「削除」は反映されない。完全リセットは reload（下記）
zmodload -F zsh/stat b:zstat   # fork せずに mtime を取れる組み込み stat（毎プロンプト実行のため）
_zshrc_mtime=$(zstat +mtime ~/.zshrc)
function source-zshrc-if-updated() {
  local mtime=$(zstat +mtime ~/.zshrc)
  (( mtime == _zshrc_mtime )) && return
  _zshrc_mtime=$mtime
  # 壊れた設定を開いている全ターミナルに波及させないよう、構文チェックが通ったときだけ読み込む
  if zsh -n ~/.zshrc 2>/dev/null; then
    source ~/.zshrc
    print "(reloaded ~/.zshrc)"
  else
    print "(skipped reload: syntax error in ~/.zshrc)"
  fi
}
add-zsh-hook precmd source-zshrc-if-updated

# reload: シェルを丸ごと再起動して設定をクリーンに読み直す
# （自動リロードと違い、設定の削除も反映される。カレントディレクトリ・履歴は保持）
alias reload='exec zsh'

# starship: モダンなプロンプト（デフォルト設定のまま使用。~/.config/starship.toml は不要）
# 目的は「打ったコマンド」と「その出力(stdout)」の視認性向上。デフォルトで効くのは次の 2 点:
#   - 各プロンプトの前に空行を挿入 → 「コマンド + 出力」が 1 ブロックに視覚的にまとまる
#   - プロンプト記号 ❯ に色（直前コマンドが失敗すると赤）→ 入力開始位置と成否が一目で分かる
# ※「前後コマンドへのジャンプ」は Ghostty 自身の shell integration（zsh へ OSC 133 を自動注入）で
#   別途成立しており、starship の効果ではない（starship はデフォルトで OSC 133 を出さない）。
# ※ 自動リロード（precmd での再 source）で init が繰り返されると starship の zle-keymap-select
#   widget が累積ラップされ自己再帰しうるため、非 export フラグで「そのシェルで一度だけ」に絞る。
#   （starship が export する STARSHIP_SHELL は exec zsh=reload に引き継がれ init を握り潰すので使わない）
if command -v starship >/dev/null 2>&1 && [[ -z ${_STARSHIP_INITED:-} ]]; then
  eval "$(starship init zsh)"
  _STARSHIP_INITED=1
fi
