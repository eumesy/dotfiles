export PATH="$HOME/.local/bin:$PATH"
typeset -U path PATH  # PATH の重複エントリを自動排除（zshrc を再 source しても増えない）

# fzf のキーバインド・補完 (Ctrl-R 履歴検索など)
source <(fzf --zsh)

# Ctrl-] : ghq 管理下のリポジトリを fzf でインクリメンタル検索して cd
function ghq-fzf() {
  local repo=$(ghq list | fzf --reverse --height 40%)
  [ -n "$repo" ] && cd "$(ghq root)/$repo" && zle reset-prompt
}
zle -N ghq-fzf
bindkey '^]' ghq-fzf

# コマンド履歴をファイルに保存（これが無いと Ctrl-R = fzf 履歴検索がセッションを跨げない）
# macOS デフォルト（/etc/zshrc の SAVEHIST=1000）を引き上げる。ファイルは同じ ~/.zsh_history
HISTFILE=~/.zsh_history
HISTSIZE=100000              # メモリ上に保持する件数
SAVEHIST=100000              # ファイルに保存する件数
setopt hist_ignore_all_dups  # 重複コマンドは最新のみ残す
setopt share_history         # 複数セッション間で履歴を共有
setopt extended_history      # 実行時刻・所要時間も記録

# 入力途中の文字列から始まる履歴を Ctrl-P / Ctrl-N で遡る/進む
autoload -Uz history-search-end
zle -N history-beginning-search-backward-end history-search-end
zle -N history-beginning-search-forward-end history-search-end
bindkey '^P' history-beginning-search-backward-end
bindkey '^N' history-beginning-search-forward-end

# zoxide: 訪れたディレクトリを frecency（頻度 + 新しさ）で自動記録
# `z <キーワード>` でジャンプ、`zi` で対話選択（fzf 使用）
eval "$(zoxide init zsh)"

# Ctrl-L : 過去に訪れたディレクトリを fzf で検索して cd（frecency 順）
function fzf-zoxide() {
  local dir=$(zoxide query --list | fzf --reverse --height 40% --no-sort)
  if [ -n "$dir" ]; then
    BUFFER="cd ${(q)dir}"
    zle accept-line
  fi
}
zle -N fzf-zoxide
bindkey '^l' fzf-zoxide

# 補完を有効化し、候補にファイル種別の色を付ける（LS_COLORS は 2021 年設定を踏襲）
autoload -Uz compinit && compinit
export LS_COLORS='di=01;36:ln=01;35:ex=01;32'
zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}

# ls: eza（exa 後継のモダン ls。色・git 状態・tree 表示・アイコン）。無ければ BSD ls で代替
# --icons=auto: 出力が端末のときだけ Nerd Font グリフのアイコンを付ける（パイプ時は付かない）。
# 表示には Nerd Font が必要（Ghostty は内蔵。VS Code ターミナルは vscode/settings.json の
# terminal.integrated.fontFamily + Brewfile の font-jetbrains-mono-nerd-font で対応）
if command -v eza >/dev/null 2>&1; then
  alias ls='eza -A --icons=auto'                   # 隠しファイル込み（2021 年の ls -A を踏襲）
  alias ll='eza -lhA --git --icons=auto'           # 詳細表示 + git 状態（旧 ll='ls -lhGAF' 相当）
  alias lt='eza -A --tree --level=2 --icons=auto'  # 2 階層のツリー表示
else
  alias ls='ls -AGF'
  alias ll='ls -lhAGF'
fi

# less: bat（syntax highlight 付き cat/pager）を前処理にして less 内でハイライト表示
# LESSOPEN: less がファイルを開くときに bat で色付けする（`cmd | less` のパイプ入力は対象外）
# LESS=-R: 色の ANSI エスケープをそのまま解釈して表示
# --style=plain: 行番号や枠を付けない（less らしい見た目のまま。コピーも汚れない）
if command -v bat >/dev/null 2>&1; then
  export LESSOPEN='| bat --color=always --style=plain %s'
  export LESS='-R'
fi

# cd 直後に ls を自動実行（2021 年の chpwd() を踏襲。zoxide のフックと共存できる add-zsh-hook 方式）
# ※ 直前で定義した ls エイリアス（= eza）がこの関数の定義時に展開される
# ※ eza は「引数なし + stdin が非端末」だと stdin からパス一覧を読む仕様のため、明示的に . を渡す
autoload -Uz add-zsh-hook
function ls-on-chpwd() {
  ls .
}
add-zsh-hook chpwd ls-on-chpwd

# ~/.zshrc（の実体）が更新されていたら、次のプロンプト表示前に自動で再読み込み
# （dotfiles の編集・pull 後、開いている各ターミナルは Enter を打つだけで反映される）
# ※ source の重ね掛けのため設定の「削除」は反映されない。完全リセットは reload（下記）
zmodload -F zsh/stat b:zstat   # fork せずに mtime を取れる組み込み stat（毎プロンプト実行のため）
_zshrc_mtime=$(zstat +mtime ~/.zshrc)
function source-zshrc-if-updated() {
  local mtime=$(zstat +mtime ~/.zshrc)
  (( mtime == _zshrc_mtime )) && return
  _zshrc_mtime=$mtime
  # 壊れた設定を開いている全ターミナルに波及させないよう、構文チェックが通ったときだけ読み込む
  if zsh -n ~/.zshrc 2>/dev/null; then
    source ~/.zshrc
    print "(~/.zshrc を再読み込みしました)"
  else
    print "(~/.zshrc に構文エラーがあるため再読み込みをスキップしました)"
  fi
}
add-zsh-hook precmd source-zshrc-if-updated

# reload: シェルを丸ごと再起動して設定をクリーンに読み直す
# （自動リロードと違い、設定の削除も反映される。カレントディレクトリ・履歴は保持）
alias reload='exec zsh'
